# Variáveis de ambiente — copie para .env.local e preencha.
# No deploy (Vercel), cadastre estas mesmas chaves em Project Settings → Environment Variables.

# Supabase (Painel → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SMTP do cliente (envio dos formulários SAC / Trabalhe Conosco)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Forneria Original <siteforneria@onchannel.io>"
